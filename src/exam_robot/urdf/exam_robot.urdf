<?xml version="1.0"?>
<robot name="exam_robot">

  <!-- материалы -->
  <material name="blue">
    <color rgba="0 0 1 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="red">
    <color rgba="1 0 0 1"/>
  </material>

  <!-- base_link (корпус) -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.4 0.3 0.1"/>
      </geometry>
      <material name="blue"/>
    </visual>
  </link>

  <!-- left_wheel (левое колесо) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <!-- Поворот вокруг Y на 90° -->
      <origin rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- x=-0.1 (чуть назад), y=+0.17 (слева), z=-0.05 (низ корпуса) -->
    <origin xyz="-0.1 0.17 -0.05" rpy="0 0 0"/>
    <!-- Ось вращения вокруг Z -->
    <axis xyz="0 0 1"/>
  </joint>

  <!-- right_wheel (правое колесо) -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder radius="0.08" length="0.04"/>
      </geometry>
      <origin rpy="0 1.5708 0"/>
      <material name="black"/>
    </visual>
  </link>
  
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.1 -0.17 -0.05" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- sensor_link (датчик) -->
  <link name="sensor_link">
    <visual>
      <geometry>
        <box size="0.05 0.05 0.05"/>
      </geometry>
      <material name="red"/>
    </visual>
  </link>
  
  <joint name="sensor_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sensor_link"/>
    <origin xyz="0.2 0 0.08" rpy="0 0 0"/>
  </joint>

</robot>
